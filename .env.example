# --- GESTIFIQUE3 CONFIGURATION EXAMPLE ---
# Duplique este arquivo como .env e preencha as informacoes reais para producao.

NODE_ENV=production
PORT=3000
# JWT_SECRET: OBRIGATORIO. Use uma chave aleatoria com no minimo 32 caracteres.
# Gere uma com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# O boot em producao ABORTA se o segredo for curto (<32) ou um valor de exemplo conhecido.
JWT_SECRET=COLE_AQUI_UMA_CHAVE_ALEATORIA_FORTE_COM_MAIS_DE_32_CHARS
# Timezone usado pelos calculos Node.js de SLA e datas operacionais.
APP_TIMEZONE=America/Sao_Paulo

# --- BANCO DE DADOS (MYSQL / MARIADB) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=gestifique_db
DB_PORT=3306
# Pool MySQL. Ajuste conforme CPU/RAM e limite do banco.
# DB_QUEUE_LIMIT=100 evita fila infinita em picos; use 0 apenas conscientemente.
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=100
DB_CONNECT_TIMEOUT_MS=10000

# --- MIGRATIONS / DDL ---
# Em producao, mantenha false e rode npm run db:migrate antes do start.
# Em desenvolvimento, se ausente, o sistema roda migrations no boot.
AUTO_RUN_MIGRATIONS=false

# --- CONTA DE DESENVOLVEDOR INICIAL ---
# Usada apenas para o PRIMEIRO acesso (seed). Defina uma senha forte e unica
# e troque-a apos o primeiro login. NAO reutilize esta senha em outros lugares.
DEV_EMAIL=admin@gestifique.com.br
DEV_PASSWORD=DEFINA_UMA_SENHA_FORTE_E_UNICA

# --- PROXY & INFRAESTRUTURA ---
# TRUST_PROXY: necessario para que o express-rate-limit funcione corretamente atras de um proxy.
# Use '1' para Hostinger/Nginx/Cloudflare (confia no primeiro salto).
# Use 'false' para desenvolvimento local direto.
TRUST_PROXY=1

# --- CORS & SEGURANCA ---
# Separe multiplos dominios por virgula.
CORS_ORIGINS=https://gestifique.com.br,https://app.gestifique.com.br

# --- TLS DE E-MAIL ---
# Padrao SEGURO: a validacao de certificado TLS (SMTP/IMAP) fica ATIVA.
# Defina MAIL_TLS_INSECURE=true APENAS em ambiente controlado com certificado
# invalido/self-signed. Isso DESATIVA a validacao TLS e e INSEGURO (risco de MITM).
# Deixe ausente ou =false em producao real.
MAIL_TLS_INSECURE=false

# --- ESCALABILIDADE & PROCESSOS (WORKLOAD SEPARATION) ---
# Em servidores pequenos (instancia unica), mantenha tudo ligado:
#   ENABLE_WEB_SERVER=true, ENABLE_TICKET_JOBS=true, ENABLE_EMAIL_LISTENER=false
#   (ative o listener apenas apos configurar IMAP).
#
# Em PRODUCAO MULTI-INSTANCIA, separe os papeis em dois processos:
#
#   Instancia WEB (atende HTTP/API/Socket.io):
#     ENABLE_WEB_SERVER=true
#     ENABLE_TICKET_JOBS=false
#     ENABLE_EMAIL_LISTENER=false
#
#   Instancia WORKER (roda automacoes + listener de e-mail) - mantenha UMA:
#     ENABLE_WEB_SERVER=false
#     ENABLE_TICKET_JOBS=true
#     ENABLE_EMAIL_LISTENER=true
#
# Notas:
# - As automacoes (runTicketAutomations) sao protegidas por lock distribuido
#   via MySQL GET_LOCK(): mesmo que mais de um processo tente rodar, apenas um
#   executa por ciclo. Ainda assim, prefira concentrar os jobs no worker.
# - GET_LOCK protege os JOBS, mas NAO resolve Socket.io entre varias instancias web.
#   Para multiplas WEBs com tempo real consistente, sera necessario o Redis adapter
#   do Socket.io (fase futura).
# - O e-mail listener deve rodar em UM worker unico por enquanto.
ENABLE_WEB_SERVER=true
ENABLE_TICKET_JOBS=true
ENABLE_EMAIL_LISTENER=false

# Token secreto para cron interno da Hostinger chamar jobs protegidos.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_JOB_TOKEN=COLE_AQUI_UM_TOKEN_FORTE_PARA_JOBS_INTERNOS
# Por seguranca, prefira cron com header x-internal-job-token via POST.
# Ative true apenas se o cron da Hostinger nao permitir header customizado.
ALLOW_INTERNAL_JOB_TOKEN_IN_QUERY=false

# --- STORAGE ---
# 'local' salva no disco. 's3' e 'gcs' reservados para o futuro.
# Na Hostinger, crie uma pasta "uploads" na raiz, ao lado de nodejs e public_html.
# Estrutura esperada:
#   uploads/tickets   -> anexos de chamados
#   uploads/profiles  -> fotos de perfil
STORAGE_TYPE=local
# Se ausente ou igual a uploads/tickets, o app salva anexos em ../uploads/tickets.
UPLOAD_DIR=../uploads/tickets
# Se ausente, o app salva fotos em ../uploads/profiles.
# Use caminho absoluto apenas se quiser sobrescrever o padrao.
# Exemplo: PROFILE_UPLOAD_DIR=/home/u123456789/uploads/profiles
PROFILE_UPLOAD_DIR=

# --- REDIS (OPCIONAL) ---
# Redis e OPCIONAL. Sem REDIS_URL, o sistema roda em modo SINGLE-INSTANCE
# (comportamento atual) e nada de Redis e usado.
# Se a conexao falhar, o sistema NAO cai: apenas loga um aviso e segue sem Redis.
# Em fase futura, o Redis sera usado para:
#   - Socket.io Redis adapter (tempo real consistente entre varias instancias web)
#   - emitter no worker (eventos do listener de e-mail chegando as webs)
#   - invalidacao distribuida do cache de permissoes
# Para PRODUCAO com MULTIPLAS INSTANCIAS, recomenda-se um Redis gerenciado.
# Exemplos: redis://localhost:6379  |  rediss://default:senha@host:6379 (TLS)
# REDIS_URL=redis://localhost:6379

# --- OMNICHANNEL / EMAIL LISTENER (OPCIONAL) ---
# Apenas ative se ENABLE_EMAIL_LISTENER=true e as credenciais abaixo estiverem preenchidas.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# Configuracoes de recebimento inteligente.
INBOUND_EMAIL_DOMAIN=inbound.gestifique.com.br
INBOUND_EMAIL_PREFIX=canal

# Confirma automaticamente e-mails de validacao de encaminhamento recebidos no
# inbound tecnico (ex.: Gmail, Yahoo/AOL, Cloudflare, Proton, Squarespace, Zoho).
# Por seguranca, o sistema so acessa links HTTPS em hosts permitidos.
AUTO_CONFIRM_EMAIL_FORWARDING=true
FORWARDING_CONFIRMATION_ALLOWED_HOSTS=mail.google.com,mail-settings.google.com,isolated.mail.google.com,login.yahoo.com,mail.yahoo.com,account.yahoo.com,api.login.yahoo.com,login.aol.com,mail.aol.com,account.aol.com,api.login.aol.com,dash.cloudflare.com,account.proton.me,mail.proton.me,proton.me,account.squarespace.com,domains.squarespace.com,squarespace.com,www.squarespace.com,accounts.zoho.com,mail.zoho.com,accounts.zoho.eu,mail.zoho.eu,accounts.zoho.in,mail.zoho.in,accounts.zoho.com.au,mail.zoho.com.au,accounts.zoho.jp,mail.zoho.jp,accounts.zohocloud.ca,mail.zohocloud.ca

# --- ENVIO DE RESPOSTA DE TICKET POR CANAL (SMTP DA EMPRESA) ---
# O cliente final deve receber a resposta com a identidade da EMPRESA
# (From: suporte@empresa.com.br), e nao com o e-mail global do Gestifique.
# Para isso, cada canal de e-mail pode ter um SMTP proprio (configurado no painel),
# e a senha SMTP e armazenada CIFRADA usando ENCRYPTION_KEY.
#
# ENCRYPTION_KEY: passphrase forte (>=16 chars) para cifrar segredos (senha SMTP do canal).
# Obrigatoria quando ha SMTP por canal configurado. Gere uma com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=COLE_AQUI_UMA_PASSPHRASE_FORTE
#
# ALLOW_GLOBAL_TICKET_EMAIL_FALLBACK: padrao SEGURO = false.
# Com false, se o canal NAO tiver SMTP configurado, a resposta NAO sai com a
# identidade global do Gestifique (vira erro controlado). Ative (=true) apenas
# se aceitar conscientemente que o cliente final possa receber e-mail do dominio
# do Gestifique como fallback.
ALLOW_GLOBAL_TICKET_EMAIL_FALLBACK=false

# --- WhatsApp Cloud API (Meta) ---
# Onde pegar cada valor (developers.facebook.com → seu app):
#   ENABLE_WHATSAPP              → true para ligar o modulo no Gestifique
#   WHATSAPP_PHONE_NUMBER_ID     → WhatsApp → Configuracao da API → Phone number ID
#   WHATSAPP_BUSINESS_ACCOUNT_ID → WhatsApp → Configuracao da API → WhatsApp Business Account ID
#   WHATSAPP_ACCESS_TOKEN        → WhatsApp → Configuracao da API → Token de acesso
#   WHATSAPP_VERIFY_TOKEN        → VOCE inventa; use o mesmo no Webhook da Meta
#   META_APP_SECRET              → Configuracoes → Basico → Segredo do app
#   WHATSAPP_DISPLAY_PHONE_NUMBER→ numero com DDI, ex. 5511999999999
#   FRONTEND_URL                 → URL HTTPS publica (monta a callback do webhook)
ENABLE_WHATSAPP=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v25.0
# META_APP_SECRET=
# WHATSAPP_DISPLAY_PHONE_NUMBER=
# FRONTEND_URL=https://gestifique.com.br

# Auto-reply: quando o cliente mandar exatamente a palavra do TRIGGER, envia o menu com botoes.
# ENABLE_WHATSAPP_AUTO_REPLY=true
# WHATSAPP_AUTO_REPLY_TRIGGER=teste
# WHATSAPP_WELCOME_HEADER=MetaBit - Sistemas para Gestão Pública
# WHATSAPP_WELCOME_BODY=Seja Bem-Vindo, antes de iniciarmos seu atendimento, sobre qual sistema gostaria de falar?
# WHATSAPP_WELCOME_BUTTONS=pgp:Gestão Pública|pci:Controle Interno|pts:Terceiro Setor
