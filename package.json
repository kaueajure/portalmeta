{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server/server.ts",
    "dev:worker": "tsx server/worker.ts",
    "db:migrate": "tsx server/db/migrate.ts",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist-server/server.js",
    "start:worker": "node dist-server/worker.js",
    "preview": "vite preview",
    "clean": "rimraf dist dist-server",
    "lint": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "tsx --test \"tests/**/*.test.ts\"",
    "test:e2e": "tsx --test \"tests/e2e/**/*.test.ts\"",
    "postinstall": "npm run build"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "brace-expansion": "5.0.6",
    "engine.io": "6.6.9",
    "engine.io-client": "6.6.6",
    "qs": "6.15.3",
    "socket.io-adapter": "2.5.8",
    "utf7": {
      "semver": "5.7.2"
    },
    "ws": "8.21.0"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@uiw/react-md-editor": "^4.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "imap-simple": "^5.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "mailparser": "^3.9.12",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "mysql2": "^3.22.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "rimraf": "^6.1.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@types/imap-simple": "^4.2.10",
    "@types/mailparser": "^3.4.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1"
  }
}
